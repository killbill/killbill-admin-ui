<div class="kaui-container kaui-queues-index">
  <%= render "kaui/components/breadcrumb/breadcrumb" %>
  <div class="d-flex w-100" style="gap: 4rem;">
    <%= render :template => 'kaui/layouts/kaui_account_sidebar' %>
    <div class="queues w-100">

      <div class="queues-main-header mb-4 d-flex justify-content-between align-items-start">
        <div>
          <h1 class="queues-title">Queues</h1>
          <p class="queues-subtitle">View and monitor bus events and notifications.</p>
        </div>
        <%= render "kaui/components/button/button", {
          label: "Download JSON",
          icon: 'kaui/download.svg',
          html_class: "kaui-button custom-hover",
          variant: "btn-outline-secondary d-inline-flex align-items-center gap-1",
          type: "button",
          html_options: {
            id: "queuesDownloadButton",
            onclick: "downloadActiveQueuesTab()"
          }
        } %>
      </div>

      <div class="queues-card">

        <% show_notifications = params[:queue_tab] == 'notifications' ||
                                  (params[:queue_tab].blank? &&
                                   (@queues_entries['busEvents'] || []).empty? &&
                                   (@queues_entries['notifications'] || []).any?) %>
        <ul class="nav nav-tabs queues-nav-tabs px-4" id="queuesNavTabs">
          <li class="nav-item">
            <a class="nav-link queues-tab-link <%= show_notifications ? '' : 'active' %>"
               id="busEvents-tab"
               href="#busEvents"
               data-bs-toggle="tab">
              <%= image_tag "kaui/sidebar/queues.svg", width: 16, height: 16, class: "me-1 tab-icon" %>
              Bus Events
            </a>
          </li>
          <li class="nav-item">
            <a class="nav-link queues-tab-link <%= show_notifications ? 'active' : '' %>"
               id="notifications-tab"
               href="#notifications"
               data-bs-toggle="tab">
              <%= image_tag "kaui/setting/e-notifications.svg", width: 16, height: 16, class: "me-1 tab-icon" %>
              Notifications
            </a>
          </li>
        </ul>

        <div class="tab-content">

          <%# Bus Events pane %>
          <div class="tab-pane fade <%= show_notifications ? '' : 'show active' %>" id="busEvents">
            <div class="queues-pane-inner">

              <div class="queues-controls-bar mb-4">
                <div class="d-flex align-items-center gap-3">
                  <span class="time-scope-label">Time scope</span>
                  <div class="d-flex gap-2">
                    <%= link_to kaui_engine.queues_path(
                          params.to_unsafe_h.except(:min_date, :max_date, :tab, :with_history, :queue_tab)
                                .merge(with_history: 'false', tab: 'future',
                                       max_date: (@now + 1.week).utc.iso8601, queue_tab: 'busEvents')
                        ),
                        class: "time-scope-btn #{params[:tab].blank? || params[:tab] == 'future' ? 'active' : ''}" do %>
                      <span class="radio-dot"></span>
                      Current / Future
                    <% end %>
                    <%= link_to kaui_engine.queues_path(
                          params.to_unsafe_h.except(:min_date, :max_date, :tab, :with_history, :queue_tab)
                                .merge(with_history: 'true', tab: 'all', queue_tab: 'busEvents')
                        ),
                        class: "time-scope-btn #{['week', 'month', 'all'].include?(params[:tab]) ? 'active' : ''}" do %>
                      <span class="radio-dot"></span>
                      Historical
                    <% end %>
                  </div>
                </div>
                <div class="queues-search-bar">
                  <label class="search-label" for="bus-search">Search:</label>
                  <div class="search-input-group">
                    <input type="text" id="bus-search" class="queues-search-input" placeholder="Search events...">
                    <span class="search-icon">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#9ca3af" stroke-width="2.5">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                      </svg>
                    </span>
                  </div>
                </div>
              </div>

              <div class="<%= params[:account_id].present? ? 'max-width-67' : 'max-width-80' %>">
                <table id="bus-table" class="bus-table">
                  <thead>
                    <tr>
                      <th></th>
                      <th class="sortable-header" data-column="1">
                        <div class="header-content">
                          <span class="header-text">Created date</span>
                          <div class="sort-icons">
                            <%= image_tag "kaui/sort-up.svg", class: "sort-icon sort-asc" %>
                            <%= image_tag "kaui/sort-down.svg", class: "sort-icon sort-desc" %>
                          </div>
                        </div>
                      </th>
                      <th class="sortable-header" data-column="2">
                        <div class="header-content">
                          <span class="header-text">Class name</span>
                          <div class="sort-icons">
                            <%= image_tag "kaui/sort-up.svg", class: "sort-icon sort-asc" %>
                            <%= image_tag "kaui/sort-down.svg", class: "sort-icon sort-desc" %>
                          </div>
                        </div>
                      </th>
                      <th class="sortable-header" data-column="3">
                        <div class="header-content">
                          <span class="header-text">Event</span>
                          <div class="sort-icons">
                            <%= image_tag "kaui/sort-up.svg", class: "sort-icon sort-asc" %>
                            <%= image_tag "kaui/sort-down.svg", class: "sort-icon sort-desc" %>
                          </div>
                        </div>
                      </th>
                      <th class="sortable-header" data-column="4">
                        <div class="header-content">
                          <span class="header-text">User token</span>
                          <div class="sort-icons">
                            <%= image_tag "kaui/sort-up.svg", class: "sort-icon sort-asc" %>
                            <%= image_tag "kaui/sort-down.svg", class: "sort-icon sort-desc" %>
                          </div>
                        </div>
                      </th>
                      <% if @account_id.blank? %>
                        <th class="sortable-header" data-column="5">
                          <div class="header-content">
                            <span class="header-text">Account record id</span>
                            <div class="sort-icons">
                              <%= image_tag "kaui/sort-up.svg", class: "sort-icon sort-asc" %>
                              <%= image_tag "kaui/sort-down.svg", class: "sort-icon sort-desc" %>
                            </div>
                          </div>
                        </th>
                      <% end %>
                    </tr>
                  </thead>
                  <tbody>
                    <% (@queues_entries['busEvents'] || []).each do |bus_event| %>
                      <tr>
                        <td class="timeline">
                          <span class="dot"></span>
                        </td>
                        <td><span><%= truncate_millis(bus_event['createdDate']) %></span></td>
                        <td data-full-value="<%= bus_event['className'] %>"><%= truncate_class_name(bus_event['className'], false) %></td>
                        <td><%= "<pre>#{JSON.pretty_generate(bus_event['event'])}</pre>".html_safe %></td>
                        <td><%= bus_event['userToken'] %></td>
                        <% if @account_id.blank? %>
                          <td><%= bus_event['searchKey1'] %></td>
                        <% end %>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>

            </div>
          </div>

          <%# Notifications pane %>
          <div class="tab-pane fade <%= show_notifications ? 'show active' : '' %>" id="notifications">
            <div class="queues-pane-inner">

              <div class="queues-controls-bar mb-4">
                <div class="d-flex align-items-center gap-3">
                  <span class="time-scope-label">Time scope</span>
                  <div class="d-flex gap-2">
                    <%= link_to kaui_engine.queues_path(
                          params.to_unsafe_h.except(:min_date, :max_date, :tab, :with_history, :queue_tab)
                                .merge(with_history: 'false', tab: 'future',
                                       max_date: (@now + 1.week).utc.iso8601, queue_tab: 'notifications')
                        ),
                        class: "time-scope-btn #{params[:tab].blank? || params[:tab] == 'future' ? 'active' : ''}" do %>
                      <span class="radio-dot"></span>
                      Current / Future
                    <% end %>
                    <%= link_to kaui_engine.queues_path(
                          params.to_unsafe_h.except(:min_date, :max_date, :tab, :with_history, :queue_tab)
                                .merge(with_history: 'true', tab: 'all', queue_tab: 'notifications')
                        ),
                        class: "time-scope-btn #{['week', 'month', 'all'].include?(params[:tab]) ? 'active' : ''}" do %>
                      <span class="radio-dot"></span>
                      Historical
                    <% end %>
                  </div>
                </div>
                <div class="queues-search-bar">
                  <label class="search-label" for="notifications-search">Search:</label>
                  <div class="search-input-group">
                    <input type="text" id="notifications-search" class="queues-search-input" placeholder="Search events...">
                    <span class="search-icon">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="#9ca3af" stroke-width="2.5">
                        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                      </svg>
                    </span>
                  </div>
                </div>
              </div>

              <div class="<%= params[:account_id].present? ? 'max-width-67' : 'max-width-80' %>">
                <table id="notifications-table" class="notifications-table">
                  <thead>
                    <tr>
                      <th></th>
                      <th class="sortable-header" data-column="1">
                        <div class="header-content">
                          <span class="header-text">Effective date</span>
                          <div class="sort-icons">
                            <%= image_tag "kaui/sort-up.svg", class: "sort-icon sort-asc" %>
                            <%= image_tag "kaui/sort-down.svg", class: "sort-icon sort-desc" %>
                          </div>
                        </div>
                      </th>
                      <th class="sortable-header" data-column="2">
                        <div class="header-content">
                          <span class="header-text">Queue name</span>
                          <div class="sort-icons">
                            <%= image_tag "kaui/sort-up.svg", class: "sort-icon sort-asc" %>
                            <%= image_tag "kaui/sort-down.svg", class: "sort-icon sort-desc" %>
                          </div>
                        </div>
                      </th>
                      <th class="sortable-header" data-column="3">
                        <div class="header-content">
                          <span class="header-text">Event</span>
                          <div class="sort-icons">
                            <%= image_tag "kaui/sort-up.svg", class: "sort-icon sort-asc" %>
                            <%= image_tag "kaui/sort-down.svg", class: "sort-icon sort-desc" %>
                          </div>
                        </div>
                      </th>
                      <th class="sortable-header" data-column="4">
                        <div class="header-content">
                          <span class="header-text">User token</span>
                          <div class="sort-icons">
                            <%= image_tag "kaui/sort-up.svg", class: "sort-icon sort-asc" %>
                            <%= image_tag "kaui/sort-down.svg", class: "sort-icon sort-desc" %>
                          </div>
                        </div>
                      </th>
                      <% if @account_id.blank? %>
                        <th class="sortable-header" data-column="5">
                          <div class="header-content">
                            <span class="header-text">Account record id</span>
                            <div class="sort-icons">
                              <%= image_tag "kaui/sort-up.svg", class: "sort-icon sort-asc" %>
                              <%= image_tag "kaui/sort-down.svg", class: "sort-icon sort-desc" %>
                            </div>
                          </div>
                        </th>
                      <% end %>
                    </tr>
                  </thead>
                  <tbody>
                    <% (@queues_entries['notifications'] || []).each do |notification| %>
                      <tr>
                        <td class="timeline">
                          <div class="dot"></div>
                        </td>
                        <td><span><%= truncate_millis(notification['effectiveDate']) %></span></td>
                        <td><%= notification['queueName'] %></td>
                        <td><%= "<pre>#{JSON.pretty_generate(notification['event'])}</pre>".html_safe %></td>
                        <td><%= notification['userToken'] %></td>
                        <% if @account_id.blank? %>
                          <td><%= notification['searchKey1'] %></td>
                        <% end %>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>

            </div>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>

<%= javascript_tag do %>
  function downloadActiveQueuesTab() {
    var activeTab = $('#queuesNavTabs .nav-link.active').attr('id');
    var tableId, filename;
    if (activeTab === 'notifications-tab') {
      tableId = '#notifications-table';
      filename = 'notifications-' + new Date().toISOString().split('T')[0] + '.json';
    } else {
      tableId = '#bus-table';
      filename = 'bus-events-' + new Date().toISOString().split('T')[0] + '.json';
    }

    var table = $(tableId).DataTable();
    var headers = [];
    var visibleColumnIndexes = [];

    $(tableId + ' thead th').each(function(index) {
      if (index === 0) return; // skip timeline dot column
      var column = table.column(index);
      if (column.visible()) {
        var headerText = $(this).find('.header-text').text().trim();
        headers.push(headerText);
        visibleColumnIndexes.push(index);
      }
    });

    var jsonRows = [];

    table.rows({ search: 'applied' }).nodes().each(function(row) {
      var cells = $(row).find('td');
      var obj = {};
      visibleColumnIndexes.forEach(function(colIdx, i) {
        var $cell = $(cells[colIdx]);
        var fullValue = $cell.data('full-value');
        var cellText = fullValue !== undefined ? String(fullValue) : $cell.text().trim();
        var key = headers[i];
        try {
          obj[key] = JSON.parse(cellText);
        } catch (e) {
          obj[key] = cellText;
        }
      });
      jsonRows.push(obj);
    });

    var jsonContent = JSON.stringify(jsonRows, null, 2);
    var blob = new Blob([jsonContent], { type: 'application/json;charset=utf-8;' });
    var url = URL.createObjectURL(blob);
    var a = document.createElement('a');
    a.href = url;
    a.download = filename;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  }

  $(document).ready(function() {
    var busTable = $('#bus-table').DataTable({
      "dom": "t<'row dt-footer-row'<'col-md-6'i><'col-md-6'p>>",
      "paging": true,
      "pagingType": "full_numbers",
      "pageLength": 25,
      "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
      "order": [],
      <% if @account_id.blank? %>
      "columnDefs": [{"targets": [5], "visible": false, "searchable": true}],
      <% else %>
      "columnDefs": [],
      <% end %>
      "language": {
        "paginate": {
          "first": "First",
          "last": "Last",
          "next": "Next",
          "previous": "Previous"
        },
        "lengthMenu": "Show _MENU_ entries",
        "info": "Showing _START_ to _END_ of _TOTAL_ entries",
        "infoEmpty": "Showing 0 to 0 of 0 entries",
        "infoFiltered": "(filtered from _MAX_ total entries)",
        "zeroRecords": "No matching records found"
      }
    });

    var notificationsTable = $('#notifications-table').DataTable({
      "dom": "t<'row dt-footer-row'<'col-md-6'i><'col-md-6'p>>",
      "paging": true,
      "pagingType": "full_numbers",
      "pageLength": 25,
      "lengthMenu": [[10, 25, 50, 100, -1], [10, 25, 50, 100, "All"]],
      "order": [],
      <% if @account_id.blank? %>
      "columnDefs": [{"targets": [5], "visible": false, "searchable": true}],
      <% else %>
      "columnDefs": [],
      <% end %>
      "language": {
        "paginate": {
          "first": "First",
          "last": "Last",
          "next": "Next",
          "previous": "Previous"
        },
        "lengthMenu": "Show _MENU_ entries",
        "info": "Showing _START_ to _END_ of _TOTAL_ entries",
        "infoEmpty": "Showing 0 to 0 of 0 entries",
        "infoFiltered": "(filtered from _MAX_ total entries)",
        "zeroRecords": "No matching records found"
      }
    });

    $('#bus-search').on('keyup', function() {
      busTable.search($(this).val()).draw();
    });

    $('#notifications-search').on('keyup', function() {
      notificationsTable.search($(this).val()).draw();
    });

    // Custom sorting for Bus table
    (function() {
      var currentSortColumn = -1;
      var currentSortDirection = 'asc';
      $('#bus-table thead .sortable-header').on('click', function() {
        var columnIndex = parseInt($(this).data('column'));
        var newDirection = (currentSortColumn === columnIndex && currentSortDirection === 'asc') ? 'desc' : 'asc';
        currentSortColumn = columnIndex;
        currentSortDirection = newDirection;
        updateSortIndicators($('#bus-table'), columnIndex, newDirection);
        busTable.order([columnIndex, newDirection]).draw();
      });
    })();

    // Custom sorting for Notifications table
    (function() {
      var currentSortColumn = -1;
      var currentSortDirection = 'asc';
      $('#notifications-table thead .sortable-header').on('click', function() {
        var columnIndex = parseInt($(this).data('column'));
        var newDirection = (currentSortColumn === columnIndex && currentSortDirection === 'asc') ? 'desc' : 'asc';
        currentSortColumn = columnIndex;
        currentSortDirection = newDirection;
        updateSortIndicators($('#notifications-table'), columnIndex, newDirection);
        notificationsTable.order([columnIndex, newDirection]).draw();
      });
    })();

    function updateSortIndicators($table, columnIndex, direction) {
      $table.find('.sortable-header').removeClass('sort-asc-active sort-desc-active');
      $table.find('.sort-icon').removeClass('active');
      var $header = $table.find('.sortable-header[data-column="' + columnIndex + '"]');
      $header.addClass(direction + '-active');
      $header.find('.sort-' + direction).addClass('active');
    }

    $('#bus-table').wrap('<div class="table-wrapper"></div>');
    $('#notifications-table').wrap('<div class="table-wrapper"></div>');
  });
<% end %>
